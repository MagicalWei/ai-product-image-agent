# ====================================================
# Security & Authentication
# ====================================================

# JWT Secret for signing authentication tokens (use a long random string)
JWT_SECRET=change_me_to_a_random_string

# ====================================================
# Database (PostgreSQL)
# ====================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL=true

# ====================================================
# Stripe Payment
# ====================================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ====================================================
# EmailJS Configuration
# ====================================================
EMAILJS_SERVICE_ID=service_xxx
EMAILJS_TEMPLATE_ID=template_xxx
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_ACCESS_TOKEN=your_access_token

# ====================================================
# CORS & Server
# ====================================================
CORS_ORIGIN=http://localhost:5173
PORT=3000
NODE_ENV=production
TRUST_PROXY=false

# ====================================================
# Storage (local or s3)
# ====================================================
STORAGE_TYPE=local
# If STORAGE_TYPE=s3, also set:
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=xxx
# S3_SECRET_ACCESS_KEY=xxx

# ====================================================
# AI Service (Python backend)
# ====================================================
AI_SERVICE_URL=http://localhost:8000

# ====================================================
# Chat Models
# ====================================================
# Primary cheap model (info collection)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Vision model (product image analysis)
CHAT_VISION_API_KEY=sk-xxx
CHAT_VISION_BASE_URL=https://api.openai.com/v1
CHAT_VISION_MODEL=gpt-4o

# Chat fallbacks (2 levels)
CHAT_FALLBACK_1_PROTOCOL=anthropic
CHAT_FALLBACK_1_KEY=
CHAT_FALLBACK_1_URL=https://api.anthropic.com
CHAT_FALLBACK_1_MODEL=claude-3-5-sonnet-20240620

CHAT_FALLBACK_2_PROTOCOL=openai
CHAT_FALLBACK_2_KEY=
CHAT_FALLBACK_2_URL=https://api.openai.com/v1
CHAT_FALLBACK_2_MODEL=gpt-4o-mini

# ====================================================
# Image Generation Models
# ====================================================
# Primary (Doubao/Volcengine ARK)
DOUBAO_API_KEY=ark-xxx
DOUBAO_ENDPOINT_ID=your_endpoint_id
DOUBAO_IMAGE_MODEL=doubao-seedream-5.0-lite

# Image fallbacks (3 levels)
IMAGE_FALLBACK_1_PROTOCOL=openai
IMAGE_FALLBACK_1_KEY=
IMAGE_FALLBACK_1_URL=https://api.openai.com/v1
IMAGE_FALLBACK_1_MODEL=dall-e-3

IMAGE_FALLBACK_2_PROTOCOL=openai
IMAGE_FALLBACK_2_KEY=
IMAGE_FALLBACK_2_URL=https://api.openai.com/v1
IMAGE_FALLBACK_2_MODEL=dall-e-2

IMAGE_FALLBACK_3_PROTOCOL=anthropic
IMAGE_FALLBACK_3_KEY=
IMAGE_FALLBACK_3_URL=https://api.anthropic.com
IMAGE_FALLBACK_3_MODEL=claude-3-5-sonnet-20240620

# ====================================================
# Rate Limiting
# ====================================================
# Set to 'true' to bypass IP rate limiting in dev
BYPASS_IP_RATE_LIMIT=false
