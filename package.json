{
  "name": "ai-product-image-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && node server.js",
    "dev:agent": "cd backend/agent_service && python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "dev": "concurrently --kill-others-on-fail \"pnpm dev:frontend\" \"pnpm dev:backend\" \"pnpm dev:agent\"",
    "build": "cd frontend && pnpm build",
    "test": "vitest --config tests/vitest.config.js",
    "test:e2e": "playwright test --config tests/playwright.config.js"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.0.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vitest": "^3.0.7"
  }
}
